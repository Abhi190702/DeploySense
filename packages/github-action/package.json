{
  "name": "@deploysense/github-action",
  "version": "0.1.1",
  "private": true,
  "description": "GitHub Action for DeploySense scanning.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --target es2020",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/github": "^9.1.1",
    "@deploysense/compose-scanner": "workspace:*",
    "@deploysense/docker-scanner": "workspace:*",
    "@deploysense/github-actions-scanner": "workspace:*",
    "@deploysense/k8s-scanner": "workspace:*",
    "@deploysense/scanner-core": "workspace:*"
  },
  "devDependencies": {
    "@vercel/ncc": "^0.38.3"
  }
}
