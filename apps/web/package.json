{
  "name": "web",
  "version": "0.1.1",
  "private": true,
  "description": "DeploySense web dashboard.",
  "scripts": {
    "dev": "next dev -p 3000",
    "build:deps": "pnpm --dir ../.. --filter @deploysense/scanner-core build",
    "build": "pnpm run build:deps && next build",
    "start": "next start -p 3000",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@deploysense/scanner-core": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "animejs": "^4.4.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "next-themes": "^0.4.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.0"
  }
}
