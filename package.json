{
  "name": "deploysense-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source DevOps intelligence platform.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm typecheck",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:generate": "tsx packages/scanner-core/src/generateDocs.ts"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@vitest/coverage-v8": "^2.1.8",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "deploysense": "workspace:*"
  }
}
