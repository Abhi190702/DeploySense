{
  "name": "deploysense-monorepo",
  "version": "0.1.1",
  "private": true,
  "description": "Open-source DevOps intelligence platform.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:api": "pnpm --filter api build",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "pnpm typecheck",
    "npm:check": "node scripts/check-npm-packages.mjs",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "docs:generate": "tsx packages/scanner-core/src/generateDocs.ts"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "tsx": "^4.19.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3"
  }
}
